<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.itbank.mall.repository.OrderRepository">

    <select id="findOrdersByMemberId" parameterType="long" resultType="com.itbank.mall.entity.Order">
        SELECT order_id, member_id, order_date, status, total_amount
        FROM orders
        WHERE member_id = #{memberId}
        ORDER BY order_date DESC
    </select>

</mapper>
